# Every VITE_* value is public and embedded in the browser bundle.
# The API URL is required for UAT/pilot/production builds and must be an exact
# HTTPS origin. Blank is supported only by the local Vite development server.
VITE_DOCUMENT_INTELLIGENCE_API_BASE_URL=

# Reserved for Phase 5. Leave blank until browser Auth integration is reviewed.
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Presentation only. These values grant no identity, tenant, role, or permission.
VITE_DEPLOYMENT_ENVIRONMENT=uat
VITE_UAT_LABEL=UAT / Technical Preview

# Optional display-only hint. The API remains the permission authority.
VITE_WORKFLOW_STUDIO_PERMISSIONS=

# Never add a Supabase secret/service-role key, database URL, JWT secret, private
# signing material, or any other server credential to a VITE_* variable.
