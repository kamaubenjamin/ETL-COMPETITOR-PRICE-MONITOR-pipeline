{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:project:matching_runtime:MatchSet:1.0.0",
  "schema_id": "urn:project:matching_runtime:MatchSet",
  "schema_version": "1.0.0",
  "version": "1.0.0",
  "title": "MatchSet",
  "description": "Serialized MatchSet produced by Matching Runtime (to_dict).",
  "type": "object",
  "properties": {
    "source_document_id": { "type": "string" },
    "matches": { "type": "array", "items": { "$ref": "#/definitions/MatchResult" } },
    "match_statistics": { "type": "object" },
    "overall_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "matching_metadata": { "type": "object" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": ["source_document_id", "matches", "match_statistics", "overall_confidence", "matching_metadata", "created_at"],
  "definitions": {
    "MatchExplanation": {
      "type": "object",
      "properties": {
        "strategy_used": { "type": "string" },
        "match_signals": { "type": "array", "items": { "type": "string" } },
        "confidence_factors": { "type": "object", "additionalProperties": { "type": "number" } },
        "fallback_strategies": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      },
      "required": ["strategy_used", "match_signals", "confidence_factors", "fallback_strategies"]
    },
    "MatchCandidate": {
      "type": "object",
      "properties": {
        "candidate_id": { "type": "string" },
        "candidate_name": { "type": "string" },
        "candidate_fields": { "type": "object" },
        "source": { "type": "string" },
        "similarity_score": { "type": "number" },
        "match_explanation": { "$ref": "#/definitions/MatchExplanation" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      },
      "required": ["candidate_id", "candidate_name", "candidate_fields", "source", "similarity_score", "match_explanation"]
    },
    "MatchResult": {
      "type": "object",
      "properties": {
        "request_id": { "type": "string" },
        "entity_id": { "type": "string" },
        "matched": { "type": "boolean" },
        "match_type": { "type": "string", "enum": ["exact", "normalized", "fuzzy", "historical", "manual"] },
        "best_match": { "oneOf": [{ "$ref": "#/definitions/MatchCandidate" }, { "type": "null" }] },
        "all_candidates": { "type": "array", "items": { "$ref": "#/definitions/MatchCandidate" } },
        "overall_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "explanation": { "$ref": "#/definitions/MatchExplanation" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["request_id", "entity_id", "matched", "match_type", "all_candidates", "overall_confidence", "explanation", "created_at"]
    }
  }
}
