{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "urn:project:entity_runtime:EntitySet:1.0.0",
  "schema_id": "urn:project:entity_runtime:EntitySet",
  "schema_version": "1.0.0",
  "version": "1.0.0",
  "title": "EntitySet",
  "description": "Serialized output of Entity Runtime (to_dict) representing entities extracted from a document.",
  "type": "object",
  "properties": {
    "source_document_id": { "type": "string" },
    "extraction_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "entity_counts": {
      "type": "object",
      "properties": {
        "references": { "type": "integer", "minimum": 0 },
        "line_items": { "type": "integer", "minimum": 0 },
        "suppliers": { "type": "integer", "minimum": 0 },
        "customers": { "type": "integer", "minimum": 0 },
        "financials": { "type": "integer", "minimum": 0 }
      },
      "required": ["references", "line_items", "suppliers", "customers", "financials"]
    },
    "references": { "type": "array", "items": { "$ref": "#/definitions/DocumentReference" } },
    "line_items": { "type": "array", "items": { "$ref": "#/definitions/LineItem" } },
    "suppliers": { "type": "array", "items": { "$ref": "#/definitions/Supplier" } },
    "customers": { "type": "array", "items": { "$ref": "#/definitions/Customer" } },
    "financials": { "type": "array", "items": { "$ref": "#/definitions/DocumentFinancials" } },
    "extraction_metadata": { "type": "object" },
    "created_at": { "type": "string", "format": "date-time" }
  },
  "required": ["source_document_id", "extraction_confidence", "entity_counts", "references", "line_items", "suppliers", "customers", "financials", "created_at"],
  "definitions": {
    "SourceLineage": {
      "type": "object",
      "properties": {
        "source_type": { "type": "string" },
        "source_path": { "type": "string" },
        "ingestion_id": { "type": "string" },
        "pipeline_run_id": { "type": "string" },
        "parsed_block_index": { "type": "integer" },
        "line_number": { "type": ["integer", "null"] },
        "extraction_rule": { "type": "string" }
      },
      "required": ["source_type", "source_path", "ingestion_id", "pipeline_run_id"]
    },
    "LineItem": {
      "type": "object",
      "properties": {
        "entity_id": { "type": "string" },
        "entity_type": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": { "$ref": "#/definitions/SourceLineage" },
        "description": { "type": "string" },
        "quantity": { "type": ["number", "null"] },
        "unit_price": { "type": ["number", "null"] },
        "total_price": { "type": ["number", "null"] },
        "unit": { "type": ["string", "null"] },
        "sku": { "type": ["string", "null"] },
        "tax_amount": { "type": ["number", "null"] },
        "discount_amount": { "type": ["number", "null"] },
        "line_number": { "type": ["integer", "null"] }
      },
      "required": ["entity_id", "entity_type", "confidence", "source", "description"]
    },
    "Supplier": {
      "type": "object",
      "properties": {
        "entity_id": { "type": "string" },
        "entity_type": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": { "$ref": "#/definitions/SourceLineage" },
        "raw_text": { "type": ["string", "null"] },
        "name": { "type": ["string", "null"] },
        "address": { "type": ["string", "null"] },
        "contact": { "type": ["string", "null"] },
        "email": { "type": ["string", "null"] },
        "phone": { "type": ["string", "null"] },
        "registration_number": { "type": ["string", "null"] }
      },
      "required": ["entity_id", "entity_type", "confidence", "source"]
    },
    "Customer": {
      "type": "object",
      "properties": {
        "entity_id": { "type": "string" },
        "entity_type": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": { "$ref": "#/definitions/SourceLineage" },
        "raw_text": { "type": ["string", "null"] },
        "name": { "type": ["string", "null"] },
        "address": { "type": ["string", "null"] },
        "contact": { "type": ["string", "null"] },
        "email": { "type": ["string", "null"] },
        "phone": { "type": ["string", "null"] },
        "customer_id": { "type": ["string", "null"] },
        "tax_id": { "type": ["string", "null"] }
      },
      "required": ["entity_id", "entity_type", "confidence", "source"]
    },
    "DocumentReference": {
      "type": "object",
      "properties": {
        "entity_id": { "type": "string" },
        "entity_type": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": { "$ref": "#/definitions/SourceLineage" },
        "raw_text": { "type": ["string", "null"] },
        "document_type": { "type": ["string", "null"] },
        "document_number": { "type": ["string", "null"] },
        "invoice_number": { "type": ["string", "null"] },
        "purchase_order": { "type": ["string", "null"] },
        "invoice_date": { "type": ["string", "null"] },
        "due_date": { "type": ["string", "null"] },
        "payment_terms": { "type": ["string", "null"] },
        "currency": { "type": ["string", "null"] },
        "document_status": { "type": ["string", "null"] }
      },
      "required": ["entity_id", "entity_type", "confidence", "source"]
    },
    "DocumentFinancials": {
      "type": "object",
      "properties": {
        "entity_id": { "type": "string" },
        "entity_type": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "source": { "$ref": "#/definitions/SourceLineage" },
        "raw_text": { "type": ["string", "null"] },
        "subtotal": { "type": ["number", "null"] },
        "tax_total": { "type": ["number", "null"] },
        "discount_total": { "type": ["number", "null"] },
        "grand_total": { "type": ["number", "null"] },
        "line_item_total": { "type": ["number", "null"] },
        "tax_rate": { "type": ["number", "null"] },
        "currency": { "type": ["string", "null"] },
        "net_total": { "type": ["number", "null"] }
      },
      "required": ["entity_id", "entity_type", "confidence", "source"]
    }
  }
}
