# Document Intelligence API / UAT server configuration
# Copy to a local .env or configure in the server project secret manager.
# Never place this file's server-only names in frontend VITE_* variables.
APP_ENV=uat
DOCUMENT_INTELLIGENCE_CORS_ALLOWED_ORIGINS=

# Supabase server boundary. URL and publishable key are non-secret, but these
# server names are currently reserved and are not consumed by the UAT API.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# SERVER-ONLY SECRETS. Currently unused by the UAT API. SUPABASE_SERVICE_ROLE_KEY
# remains the compatibility name consumed by the optional legacy ETL telemetry
# client. Never commit values or expose either name to the browser.
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Deferred PostgreSQL and hosted authentication configuration. No Phase 2
# persistence or JWT integration reads these values yet.
DATABASE_URL=
AUTH_MODE=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_JWKS_URL=

# Optional legacy ETL telemetry settings. Disabled for Document Intelligence UAT.
FLOWSYNC_TELEMETRY_ENABLED=false
FLOWSYNC_TELEMETRY_RAISE_ON_ERROR=false
SUPABASE_SCHEMA=public
SUPABASE_TIMEOUT_SECONDS=15
SUPABASE_MAX_RETRIES=3
SUPABASE_RETRY_BACKOFF_SECONDS=0.5

# Optional table-name overrides if FlowSync uses custom names.
FLOWSYNC_PIPELINE_RUNS_TABLE=pipeline_runs
FLOWSYNC_INGESTION_LOGS_TABLE=ingestion_logs
FLOWSYNC_OPERATIONAL_ALERTS_TABLE=operational_alerts
